rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Photos blog et médias du site — lecture publique, upload admin
    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /site/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
