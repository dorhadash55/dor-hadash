rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Tout utilisateur connecté (admin Google) peut lire/écrire
    // Le site limite déjà l'accès admin à dor.hadash55@gmail.com
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
